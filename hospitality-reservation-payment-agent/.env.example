# ==========================================================
# Hospitality Reservation Payment Agent
# Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------

NODE_ENV=development

HOST=0.0.0.0

PORT=8000

LOG_LEVEL=INFO

APP_URL=http://localhost:8000

# ----------------------------------------------------------
# LLM Configuration
# ----------------------------------------------------------

DEFAULT_LLM_PROVIDER=gemini

DEFAULT_LLM_MODEL=gemini-2.5-flash

GEMINI_API_KEY=your_gemini_api_key_here

OPENAI_API_KEY=your_openai_api_key_here

ANTHROPIC_API_KEY=your_claude_api_key_here

HUGGINGFACE_API_KEY=your_huggingface_api_key_here

OLLAMA_BASE_URL=http://localhost:11434

VOYAGE_API_KEY=your_voyage_api_key_here

# ----------------------------------------------------------
# Embedding Configuration
# ----------------------------------------------------------

DEFAULT_EMBEDDING_PROVIDER=mock

DEFAULT_EMBEDDING_MODEL=mock-384

VECTOR_STORE_PROVIDER=memory

ENABLE_RAG=true

# ----------------------------------------------------------
# Payment Configuration
# ----------------------------------------------------------

PAYMENT_PROVIDER_DEFAULT=stripe

DEFAULT_COUNTRY=MX

DEFAULT_CURRENCY=mxn

# ----------------------------------------------------------
# Stripe Sandbox
# ----------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ----------------------------------------------------------
# Conekta Sandbox
# ----------------------------------------------------------

CONEKTA_PRIVATE_KEY=key_test_your_conekta_key_here

CONEKTA_WEBHOOK_SECRET=your_conekta_webhook_secret_here

# ----------------------------------------------------------
# Mercado Pago Sandbox
# ----------------------------------------------------------

MERCADO_PAGO_ACCESS_TOKEN=your_mp_access_token_here

MERCADO_PAGO_WEBHOOK_SECRET=your_mp_webhook_secret_here

# ----------------------------------------------------------
# Notifications (Future)
# ----------------------------------------------------------

ENABLE_NOTIFICATIONS=false

SMTP_HOST=

SMTP_PORT=587

SMTP_USERNAME=

SMTP_PASSWORD=

TWILIO_ACCOUNT_SID=

TWILIO_AUTH_TOKEN=

TWILIO_WHATSAPP_NUMBER=

TWILIO_SMS_NUMBER=